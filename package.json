{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:capacitor": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-https://optimizador-tdah-production.up.railway.app} vite build",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "start": "NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pdfkit": "^0.17.6",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfkit": "^0.19.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-wrap-balancer": "^1.1.1",
    "vite": "^6.2.3",
    "youtube-transcript": "^1.3.1"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-arm64-gnu": "^4.1.14",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.1.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
