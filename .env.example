# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional. Preferred model(s) used to generate the action maps.
# Accepts a single model or a comma-separated priority list. The server always
# appends a built-in fallback chain (gemini-3.5-flash, gemini-3-flash-preview,
# gemini-3.1-flash-lite), so if a model runs out of daily/per-minute quota (429)
# or is overloaded (503), it automatically switches to the next available model.
# All chain models have a Gemini API free tier, so fallback works without billing.
# Example (try Flash-Lite first, then the defaults):
# GEMINI_MODEL="gemini-3.1-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional cloud sync. Keep server keys out of Vite variables and never commit .env.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# VITE_API_BASE_URL: Required for Capacitor builds. Leave empty for web (same-origin /api).
# VITE_API_BASE_URL="https://optimizador-tdah-production.up.railway.app"
# App experience switcher (profile menu). Baked into the frontend at build time.
# VITE_APP_VARIANT="classic"
# VITE_CLASSIC_APP_URL="https://optimizador-tdah-production.up.railway.app"
# VITE_COMPRENSION_APP_URL="https://nucleo-comprension-production.up.railway.app"
ALLOWED_ORIGINS="https://app.example.com"
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW_MS="600000"
MAX_UPLOAD_BYTES="15728640"
