# Copy these variables into Railway → Project → Variables.
# VITE_* must exist before the first deploy (they are baked into the frontend build).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

APP_URL=https://your-app.up.railway.app
ALLOWED_ORIGINS=https://your-app.up.railway.app

SUPABASE_URL=https://oxvfiyuljzchdjotyshl.supabase.co
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=https://oxvfiyuljzchdjotyshl.supabase.co
VITE_SUPABASE_ANON_KEY=

RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=600000
MAX_UPLOAD_BYTES=15728640

# After deploy, add APP_URL to Supabase → Authentication → URL Configuration:
# - Site URL: https://your-app.up.railway.app
# - Redirect URLs: https://your-app.up.railway.app, http://localhost:3000, com.nucleo.app://login-callback
