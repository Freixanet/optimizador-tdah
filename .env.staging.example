# Public browser configuration (safe to expose in a Vite client)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Express/Railway configuration (server-only)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
ALLOWED_ORIGINS="https://staging.example.com,https://app.example.com"
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW_MS="600000"
MAX_UPLOAD_BYTES="15728640"

# Native OAuth redirect URLs to add in Supabase Auth settings:
# - Web: https://staging.example.com (and production origin)
# - iOS/Android: com.nucleo.app://login-callback
#
# iOS: set SUPABASE_URL and SUPABASE_ANON_KEY in the Xcode scheme or CI env.
# Android: override BuildConfig.SUPABASE_* in android/app/build.gradle.kts for debug builds.
